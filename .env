# Application Host Port
APP_HOST_NAME=vpro-app
APP_PORT=8085

# Web Server Configuration
WEB_HOST_NAME=vpro-web

# Database Configuration (mySQL)
DB_HOST_PORT=3306
DB_HOST_NAME=vpro-db
DB_NAME=accounts
DB_ROOT_PASSWORD=root
DB_USER=admin_vp
DB_PASS=admin_vp

# Memcached Configuration
MEMCACHED_HOST_NAME=vpro-memcached
MEMCACHED_HOST_PORT=11211

# RabbitMQ Configuration
RABBITMQ_HOST_NAME=vpro-rabbitmq
RABBITMQ_HOST_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_SSL="false"


# ElasticSearch Docker Configuration
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_HOST_NAME=vpro-elasticsearch
ELASTICSEARCH_HOST_PORT=9200

# Spring Security Credentials
SPRING_USER=admin_vp
SPRING_PASS=admin_vp
