pipeline {
    agent any
    
    tools {
       maven 'Maven 3.9.15'
    }

    environment {
        AWS_REGION = "us-east-1"
        ECR_REGISTRY   = "943560362977.dkr.ecr.us-east-1.amazonaws.com"
        ECR_REPO = "vprofile/app"
        IMAGE_TAG  = "${BUILD_NUMBER}"
    }

    stages {

        stage('Clone') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/talkeret1/vprofile-ci-cd.git'
            }
        }

        stage('Code Quality') {
            steps {
                sh 'mvn validate checkstyle:checkstyle'
            }
        }
        
        stage('Build WAR') {
            steps {
                sh 'mvn clean verify'
            }
   
        }

        stage('SonarQube Analysis') {
            environment {
                scannerHome = tool 'SonarScanner'
            }
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                    $scannerHome/bin/sonar-scanner \
                    -Dsonar.projectKey=vprofile \
                    -Dsonar.sources=src \
                    -Dsonar.java.binaries=target/classes
                    '''
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                waitForQualityGate abortPipeline: true
            }
        }

        stage('Docker Build') {
            steps {
                sh "docker build -t $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG -t $ECR_REGISTRY/$ECR_REPO:latest -f Docker-files/app/Dockerfile ."
            }
        }

        stage('Trivy Scan') {
            steps {
                sh "trivy image --severity HIGH,CRITICAL $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG"
                // sh 'trivy image --severity HIGH,CRITICAL $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG'
            }
        }
        stage('ECR Login') {
            steps {
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-ec2-credentials']
                ])
                {
                    sh """
                        aws ecr get-login-password --region $AWS_REGION | \
                        docker login --username AWS --password-stdin $ECR_REGISTRY
                    """
                }
            }
        }

        stage('Docker Push') {
            steps {
                sh "docker push $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG"
            }
        }
    }
}