pipeline {

    agent any

    tools {
        maven 'Maven 3.9.15'
    }

    environment {
        // AWS Variables:
        AWS_REGION = "us-east-1"

        // ECR Variables:
        ECR_REGISTRY = "943560362977.dkr.ecr.us-east-1.amazonaws.com"
        ECR_REPO = "vprofile/app"
        IMAGE_TAG = "${BUILD_NUMBER}"

        // ECS Variables:
        PRIVATE_SUBNETS = "subnet-0f2f3ae85de0fa343,subnet-0e0cafc23f322ba9c"
        ECS_SECURITY_GROUP = "sg-070dfcd65aa12189c"
    }

    stages {

        stage('Clone') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/talkeret1/vprofile-ci-cd.git'
            }
        }

        stage('Code Quality') {
            steps {
                sh 'mvn validate checkstyle:checkstyle'
            }
        }

        stage('Build WAR') {
            steps {
                sh 'mvn clean verify'
            }
        }

        stage('SonarQube Analysis') {
            environment {
                scannerHome = tool 'SonarScanner'
            }
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                    $scannerHome/bin/sonar-scanner \
                    -Dsonar.projectKey=vprofile \
                    -Dsonar.sources=src/main/java \
                    -Dsonar.tests=src/test/java \
                    -Dsonar.java.binaries=target/classes \
                    -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
                    -Dsonar.java.source=21
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                waitForQualityGate abortPipeline: true
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                docker build \
                -t $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG \
                -t $ECR_REGISTRY/$ECR_REPO:latest \
                -f Docker-files/app/Dockerfile .
                """
            }
        }

        stage('Trivy Scan') {
            steps {
                sh """
                trivy image --severity HIGH,CRITICAL \
                $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG
                """
            }
        }

        stage('ECR Login') {
            steps {
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                     credentialsId: 'aws-credentials']
                ]) {
                    sh """
                    aws ecr get-login-password --region $AWS_REGION | \
                    docker login --username AWS --password-stdin $ECR_REGISTRY
                    """
                }
            }
        }

        stage('Docker Push') {
            steps {
                sh """
                docker push $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG
                docker push $ECR_REGISTRY/$ECR_REPO:latest
                """
            }
        }

        stage('Check ECS State') {
            steps {
                withCredentials([aws(credentialsId: 'aws-credentials')]) {
                    script {
                        def running = sh(
                            script: """
                            aws ecs describe-services \
                            --cluster vprofile-cluster \
                            --services vproapp-service \
                            --query "services[0].runningCount" \
                            --output text
                            """,
                            returnStdout: true
                        ).trim()

                        env.IS_FIRST_DEPLOY = (running == "0") ? "true" : "false"

                        echo "Running tasks: ${running}"
                        echo "First deploy: ${env.IS_FIRST_DEPLOY}"
                    }
                }
            }
        }

        stage('Deploy ECS Service') {
            steps {
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                     credentialsId: 'aws-credentials']
                ]) {
                    sh """
                    if [ "$IS_FIRST_DEPLOY" = "true" ]; then
                        echo "First deploy - setting desired count to 1"
                        aws ecs update-service \
                        --cluster vprofile-cluster \
                        --service vproapp-service \
                        --desired-count 1 \
                        --region $AWS_REGION
                    else
                        echo "Regular deploy - force new deployment"
                        aws ecs update-service \
                        --cluster vprofile-cluster \
                        --service vproapp-service \
                        --force-new-deployment \
                        --region $AWS_REGION
                    fi
                    """
                }
            }
        }
    }
    
    post {
        always {
            sh 'docker system prune -f'
            echo 'Docker system cleaned up.'
        }
    }
}